# Copia este fichero como .env.local y rellena los valores
# NUNCA subas .env.local a GitHub

# Tu API Key de Google Cloud (la creamos en el paso 2)
GOOGLE_DRIVE_API_KEY=pega_aqui_tu_api_key

# El ID de la carpeta "proyectos" de Google Drive (el número largo de la URL)
GOOGLE_DRIVE_FOLDER_ID=pega_aqui_el_id_de_la_carpeta
